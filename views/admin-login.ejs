<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login - Live Chat</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    body { background: #1a1a2e; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-card { background: #16213e; border-radius: 12px; padding: 40px; width: 100%; max-width: 400px; box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
    .login-card h2 { color: #e94560; text-align: center; margin-bottom: 30px; font-weight: 700; }
    .form-control { background: #0f3460; border: 1px solid #1a1a4e; color: #fff; padding: 12px; }
    .form-control:focus { background: #0f3460; color: #fff; border-color: #e94560; box-shadow: none; }
    .form-label { color: #a0a0b0; font-size: 14px; }
    .btn-login { background: #e94560; border: none; padding: 12px; font-weight: 600; width: 100%; margin-top: 10px; }
    .btn-login:hover { background: #c73650; }
    .alert { font-size: 14px; }
  </style>
</head>
<body>
  <div class="login-card">
    <h2>ADMIN PANEL</h2>
    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <form method="POST" action="/admin/login">
      <div class="mb-3">
        <label class="form-label">Username</label>
        <input type="text" name="username" class="form-control" required autofocus />
      </div>
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" required />
      </div>
      <button type="submit" class="btn btn-login btn-danger">MASUK</button>
    </form>
  </div>
</body>
</html>
