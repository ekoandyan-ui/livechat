<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - Live Chat</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #1a1a2e; color: #fff; font-family: 'Segoe UI', sans-serif; }
    .sidebar { width: 340px; min-height: 100vh; background: #16213e; border-right: 1px solid #0f3460; position: fixed; left: 0; top: 0; display: flex; flex-direction: column; }
    .sidebar-header { padding: 20px; border-bottom: 1px solid #0f3460; display: flex; align-items: center; justify-content: space-between; }
    .sidebar-header h4 { color: #e94560; font-weight: 700; margin: 0; font-size: 18px; }
    .sidebar-header a { color: #a0a0b0; text-decoration: none; font-size: 13px; }
    .sidebar-header a:hover { color: #e94560; }
    .room-list { flex: 1; overflow-y: auto; padding: 10px; }
    .room-item { padding: 15px; margin-bottom: 8px; background: #0f3460; border-radius: 10px; cursor: pointer; transition: all 0.2s; text-decoration: none; color: #fff; display: block; }
    .room-item:hover { background: #1a1a4e; border-left: 3px solid #e94560; }
    .room-item .room-name { font-weight: 600; font-size: 15px; }
    .room-item .room-meta { color: #a0a0b0; font-size: 12px; margin-top: 4px; }
    .room-item .room-badge { background: #e94560; color: #fff; border-radius: 50%; width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; float: right; }
    .room-item .last-msg { color: #808090; font-size: 12px; margin-top: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .main-content { margin-left: 340px; padding: 30px; min-height: 100vh; }
    .welcome-box { background: #16213e; border-radius: 12px; padding: 40px; text-align: center; }
    .welcome-box h2 { color: #e94560; margin-bottom: 15px; }
    .welcome-box p { color: #a0a0b0; }
    .stats { display: flex; gap: 20px; margin-top: 30px; justify-content: center; }
    .stat-card { background: #0f3460; border-radius: 10px; padding: 20px 30px; text-align: center; }
    .stat-card .stat-num { font-size: 36px; font-weight: 700; color: #e94560; }
    .stat-card .stat-label { color: #a0a0b0; font-size: 13px; margin-top: 5px; }
  </style>
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      <h4>CHAT ROOMS</h4>
      <a href="/admin/logout">Logout</a>
    </div>
    <div class="room-list">
      <% rooms.forEach(room => { %>
        <a href="/admin/room/<%= room.id %>" class="room-item">
          <span class="room-badge"><%= room.totalPesan %></span>
          <div class="room-name"><%= room.nama %></div>
          <div class="room-meta">ID: <%= room.id %> | <%= room.kelas %></div>
          <% if (room.lastMessage) { %>
            <div class="last-msg"><%= room.lastMessage.sender_name %>: <%= room.lastMessage.message %></div>
          <% } else { %>
            <div class="last-msg">Belum ada pesan</div>
          <% } %>
        </a>
      <% }) %>
    </div>
  </div>

  <div class="main-content">
    <div class="welcome-box">
      <h2>SELAMAT DATANG, <%= adminUser.toUpperCase() %></h2>
      <p>Klik salah room di sidebar untuk melihat dan mengirim pesan</p>
      <div class="stats">
        <div class="stat-card">
          <div class="stat-num"><%= rooms.length %></div>
          <div class="stat-label">Total Room</div>
        </div>
        <div class="stat-card">
          <div class="stat-num"><%= rooms.reduce((a, b) => a + b.totalPesan, 0) %></div>
          <div class="stat-label">Total Pesan</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    setInterval(() => location.reload(), 30000);
  </script>
</body>
</html>
