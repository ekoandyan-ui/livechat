<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= chatroomTitle %> - Live Chat Dinkes</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
    />
    <style>
      body {
        background: #0f172a;
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #f8fafc;
      }
      .chat-card {
        background: rgba(30, 41, 59, 0.7);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1.25rem;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
      }
      #messageList {
        height: 480px;
        overflow-y: auto;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1rem;
        padding: 1.25rem;
      }
      /* Scrollbar Styling */
      #messageList::-webkit-scrollbar {
        width: 6px;
      }
      #messageList::-webkit-scrollbar-track {
        background: rgba(15, 23, 42, 0.5);
      }
      #messageList::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 3px;
      }
      .msg-bubble {
        max-width: 75%;
        padding: 0.75rem 1rem;
        border-radius: 1rem;
        margin-bottom: 0.75rem;
        word-wrap: break-word;
      }
      .msg-self {
        background: linear-gradient(135deg, #0284c7 0%, #2563eb 100%);
        color: #fff;
        margin-left: auto;
        border-bottom-right-radius: 0.25rem;
      }
      .msg-other {
        background: rgba(51, 65, 85, 0.9);
        color: #f1f5f9;
        margin-right: auto;
        border-bottom-left-radius: 0.25rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }
      .msg-sender {
        font-size: 0.75rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
        opacity: 0.85;
      }
      .form-control-chat {
        background: rgba(15, 23, 42, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #fff;
        padding: 0.75rem 1rem;
        border-radius: 0.75rem;
      }
      .form-control-chat:focus {
        background: rgba(15, 23, 42, 0.95);
        border-color: #38bdf8;
        color: #fff;
        box-shadow: 0 0 0 0.25rem rgba(56, 189, 248, 0.25);
      }
      .btn-send {
        background: linear-gradient(135deg, #0284c7 0%, #2563eb 100%);
        border: none;
        border-radius: 0.75rem;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
      }
      .btn-send:hover {
        opacity: 0.9;
      }
    </style>
  </head>
  <body class="py-4">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <div class="chat-card p-4">
            <!-- Header -->
            <div class="d-flex align-items-center justify-content-between pb-3 mb-3 border-bottom border-secondary">
              <div>
                <h4 class="fw-bold mb-1 d-flex align-items-center text-white">
                  <i class="bi bi-chat-square-text-fill text-info me-2"></i> <%= chatroomTitle %>
                </h4>
                <p class="text-secondary small mb-0">
                  <i class="bi bi-person-circle text-success me-1"></i>
                  Terhubung sebagai: 
                  <strong class="text-light"><%= currentUser.nama %></strong> 
                  <% if (currentUser.kelas) { %>
                    <span class="badge bg-info bg-opacity-25 text-info ms-1 border border-info border-opacity-25"><%= currentUser.kelas %></span>
                  <% } else { %>
                    <span class="badge bg-purple bg-opacity-25 text-warning ms-1 border border-warning border-opacity-25">Administrator</span>
                  <% } %>
                </p>
              </div>

              <div>
                <% if (currentUser.isAdmin) { %>
                  <a href="/admin/dashboard" class="btn btn-outline-light btn-sm rounded-pill">
                    <i class="bi bi-speedometer2 me-1"></i> Dashboard Admin
                  </a>
                <% } else { %>
                  <a href="/keluar-chat" class="btn btn-outline-secondary btn-sm rounded-pill">
                    <i class="bi bi-door-open me-1"></i> Keluar Chat
                  </a>
                <% } %>
              </div>
            </div>

            <!-- Chat Area -->
            <div id="messageList" class="d-flex flex-column gap-2">
              <div class="text-center my-3 text-secondary small">
                <span class="bg-dark px-3 py-1 rounded-pill border border-secondary">
                  <i class="bi bi-shield-check text-info me-1"></i> Ruang diskusi realtime siap digunakan
                </span>
              </div>
            </div>

            <!-- Input Form -->
            <form id="chatForm" class="mt-3">
              <div class="input-group gap-2">
                <input
                  type="text"
                  class="form-control form-control-chat"
                  id="message"
                  placeholder="Ketik pesan Anda di sini..."
                  autocomplete="off"
                  required
                />
                <button type="submit" class="btn btn-send text-white shadow" id="sendMessage">
                  <i class="bi bi-send-fill me-1"></i> Kirim
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script>
      const socket = io();
      const chatForm = document.getElementById("chatForm");
      const messageInput = document.getElementById("message");
      const messageList = document.getElementById("messageList");

      const currentUser = {
        nama: "<%= currentUser.nama %>",
        kelas: "<%= currentUser.kelas || '' %>",
        isAdmin: <%= currentUser.isAdmin ? true : false %>
      };

      chatForm.addEventListener("submit", (e) => {
        e.preventDefault();
        const text = messageInput.value.trim();
        if (text) {
          const data = {
            senderNama: currentUser.nama,
            senderKelas: currentUser.kelas,
            isAdmin: currentUser.isAdmin,
            message: text,
          };

          // Emit pesan ke server
          socket.emit("message", data);

          // Tampilkan pesan sendiri di sisi kanan
          appendMessage(data, true);
          messageInput.value = "";
        }
      });

      // Menerima broadcast pesan dari user lain
      socket.on("message", (data) => {
        appendMessage(data, false);
      });

      function appendMessage(data, isSelf) {
        const wrapper = document.createElement("div");
        wrapper.className = `d-flex ${isSelf ? 'justify-content-end' : 'justify-content-start'}`;

        const bubble = document.createElement("div");
        bubble.className = `msg-bubble ${isSelf ? 'msg-self' : 'msg-other'}`;

        const senderHeader = document.createElement("div");
        senderHeader.className = "msg-sender";

        if (isSelf) {
          senderHeader.textContent = "Anda";
        } else {
          const roleLabel = data.isAdmin ? "[ADMIN]" : (data.senderKelas ? `(${data.senderKelas})` : "");
          senderHeader.textContent = `${data.senderNama} ${roleLabel}`;
        }

        const msgText = document.createElement("div");
        msgText.textContent = data.message;

        bubble.appendChild(senderHeader);
        bubble.appendChild(msgText);
        wrapper.appendChild(bubble);
        messageList.appendChild(wrapper);

        // Auto scroll to bottom
        messageList.scrollTop = messageList.scrollHeight;
      }
    </script>
  </body>
</html>
