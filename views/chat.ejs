<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forum Diskusi Realtime | Dinkes Live Chat</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      min-height: 100vh;
      color: #334155;
    }
    .chat-card {
      background: white;
      border-radius: 24px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.35);
      overflow: hidden;
    }
    .chat-header {
      background: #0f172a;
      color: white;
      padding: 20px 25px;
    }
    #messageList {
      height: 420px;
      overflow-y: auto;
      background: #f8fafc;
      border-radius: 16px;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .msg-bubble {
      max-width: 75%;
      padding: 12px 18px;
      border-radius: 18px;
      font-size: 0.95rem;
      line-height: 1.4;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .msg-self {
      align-self: flex-end;
      background: #2563eb;
      color: white;
      border-bottom-right-radius: 4px;
    }
    .msg-other {
      align-self: flex-start;
      background: white;
      color: #1e293b;
      border: 1px solid #e2e8f0;
      border-bottom-left-radius: 4px;
    }
    .msg-meta {
      font-size: 0.75rem;
      opacity: 0.75;
      margin-bottom: 2px;
      font-weight: 600;
    }
  </style>
</head>
<body class="d-flex align-items-center justify-content-center p-3">

  <div class="container" style="max-width: 800px;">
    <div class="chat-card">

      <!-- HEADER -->
      <div class="chat-header d-flex justify-content-between align-items-center">
        <div>
          <h5 class="fw-bold mb-0 d-flex align-items-center">
            <i class="bi bi-chat-dots-fill text-primary me-2"></i> <%= chatroomTitle %>
          </h5>
          <small class="text-white-50">Realtime Socket.IO Connection</small>
        </div>
        <div class="d-flex gap-2">
          <a href="/admin/dashboard" class="btn btn-sm btn-outline-light rounded-3">
            <i class="bi bi-speedometer2 me-1"></i> Dashboard Admin
          </a>
          <a href="/" class="btn btn-sm btn-light rounded-3">
            <i class="bi bi-house me-1"></i> Beranda
          </a>
        </div>
      </div>

      <div class="p-4">
        <!-- STEP 1: FORM JOIN / SET USERNAME -->
        <div id="loginContainer" class="<%= session && (session.userName || session.adminUser) ? 'd-none' : '' %>">
          <div class="alert alert-info border-0 rounded-3 mb-3">
            <i class="bi bi-info-circle me-1"></i> Masukkan nama panggilan Anda untuk bergabung ke ruang obrolan.
          </div>
          <form id="loginForm" class="d-flex gap-2">
            <input type="text" id="chatSenderName" class="form-control rounded-3" placeholder="Nama Anda (contoh: Ahmad)" value="<%= session && session.userName ? session.userName : '' %>" required>
            <button type="submit" class="btn btn-primary rounded-3 px-4 fw-bold text-nowrap" id="loginButton">
              Join Chat <i class="bi bi-arrow-right ms-1"></i>
            </button>
          </form>
        </div>

        <!-- STEP 2: CHAT CONTAINER -->
        <div id="chatContainer" class="<%= session && (session.userName || session.adminUser) ? '' : 'd-none' %>">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill fw-semibold">
              <i class="bi bi-circle-fill fs-6 me-1 text-success"></i> Connected: <span id="currentSenderLabel"><%= session && (session.userName || session.adminUser) ? (session.userName || session.adminUser) : 'Guest' %></span>
            </span>
            <small class="text-muted" id="socketIdLabel"></small>
          </div>

          <div id="messageList" class="mb-3">
            <!-- Messages inserted here -->
            <div class="text-center text-muted small my-auto" id="emptyMsgNotice">
              <i class="bi bi-chat-left-text fs-2 d-block mb-1"></i> Belum ada pesan. Mulai percakapan sekarang!
            </div>
          </div>

          <form id="chatForm" class="d-flex gap-2">
            <input type="text" class="form-control rounded-3 py-2" id="message" placeholder="Tulis pesan Anda..." required autocomplete="off">
            <button type="submit" class="btn btn-primary rounded-3 px-4 fw-bold" id="sendMessage">
              <i class="bi bi-send-fill me-1"></i> Kirim
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    const chatContainer = document.getElementById("chatContainer");
    const loginContainer = document.getElementById("loginContainer");
    const loginForm = document.getElementById("loginForm");
    const chatSenderName = document.getElementById("chatSenderName");
    const currentSenderLabel = document.getElementById("currentSenderLabel");
    const socketIdLabel = document.getElementById("socketIdLabel");
    const message = document.getElementById("message");
    const chatForm = document.getElementById("chatForm");
    const messageList = document.getElementById("messageList");
    const emptyMsgNotice = document.getElementById("emptyMsgNotice");

    let activeSender = currentSenderLabel.innerText !== 'Guest' ? currentSenderLabel.innerText : '';

    loginForm.addEventListener("submit", (e) => {
      e.preventDefault();
      if (chatSenderName.value.trim()) {
        activeSender = chatSenderName.value.trim();
        currentSenderLabel.innerText = activeSender;
        chatContainer.classList.remove("d-none");
        loginContainer.classList.add("d-none");
      }
    });

    socket.on("connect", () => {
      socketIdLabel.innerText = "ID Socket: " + socket.id;
    });

    chatForm.addEventListener("submit", (e) => {
      e.preventDefault();
      if (message.value.trim()) {
        if (emptyMsgNotice) emptyMsgNotice.style.display = "none";
        
        const text = message.value.trim();
        const data = {
          id: socket.id,
          sender: activeSender || "Anonim",
          message: text,
        };
        socket.emit("message", data);

        appendMessage(activeSender || "Saya", text, true);
        message.value = "";
      }
    });

    socket.on("message", (id, sender, msgText) => {
      if (emptyMsgNotice) emptyMsgNotice.style.display = "none";
      appendMessage(sender, msgText, false);
    });

    function appendMessage(sender, msgText, isSelf) {
      const bubble = document.createElement("div");
      bubble.className = `msg-bubble ${isSelf ? 'msg-self' : 'msg-other'}`;

      const meta = document.createElement("div");
      meta.className = "msg-meta";
      meta.innerText = isSelf ? "Anda" : sender;

      const content = document.createElement("div");
      content.innerText = msgText;

      bubble.appendChild(meta);
      bubble.appendChild(content);
      messageList.appendChild(bubble);

      messageList.scrollTop = messageList.scrollHeight;
    }
  </script>
</body>
</html>
